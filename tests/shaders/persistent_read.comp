#version 450 core

layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;
layout(rgba32f, binding = 0) uniform image2D o_out0;

uniform sampler2D history_in;

void main()
{
    vec4 value = texelFetch(history_in, ivec2(0, 0), 0);
    imageStore(o_out0, ivec2(gl_GlobalInvocationID.xy), value);
}
