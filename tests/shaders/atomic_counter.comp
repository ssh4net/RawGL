#version 450 core

layout(binding = 0, offset = 0) uniform atomic_uint counter0;
layout(rgba32f) writeonly uniform image2D o_out0;

layout(local_size_x = 1, local_size_y = 1) in;

void main()
{
    uint value = atomicCounterIncrement(counter0);
    imageStore(o_out0, ivec2(0, 0), vec4(float(value), 0.0, 0.0, 1.0));
}
