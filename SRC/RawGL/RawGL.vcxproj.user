  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <LocalDebuggerCommandArguments>-V 5 -P w:\VisualStudio\RawGL\bin\RawGL\data\color_uv.vert w:\VisualStudio\RawGL\bin\RawGL\data\color_uv.frag --pass_size 2048 2048 --cull wind ccw face bk enable true -M mesh w:\Basemesh.ply tris false --bg_color 0.18 0.18 0.18 --out outColor render.exr --out_format rgba32f --out_channels 4 --out_bits 32 --out_attr oiio:ColorSpace linear --out_attr oiio:RawColor 1 --out_attr oiio:nchannels 4 --out_attr compression jpeg:100</LocalDebuggerCommandArguments>
