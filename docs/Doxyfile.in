# SPDX-License-Identifier: Apache-2.0

PROJECT_NAME           = "@RAWGL_DOXYGEN_PROJECT_NAME@"
PROJECT_NUMBER         = "@RAWGL_DOXYGEN_PROJECT_NUMBER@"
OUTPUT_DIRECTORY       = "@RAWGL_DOXYGEN_OUTPUT_DIR@"

INPUT                  = "@RAWGL_DOXYGEN_INPUT_MAINPAGE@" "@RAWGL_DOXYGEN_INPUT_PUBLIC_HEADERS@"
FILE_PATTERNS          = *.h *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       =

USE_MDFILE_AS_MAINPAGE = "@PROJECT_SOURCE_DIR@/README.md"
STRIP_FROM_PATH        = "@PROJECT_SOURCE_DIR@"

OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = NO
OPTIMIZE_FOR_FORTRAN   = NO
OPTIMIZE_OUTPUT_VHDL   = NO

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 2
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES
QT_AUTOBRIEF           = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES

GENERATE_XML           = YES
XML_OUTPUT             = xml
XML_PROGRAMLISTING     = NO

GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_DOCBOOK       = NO

QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
